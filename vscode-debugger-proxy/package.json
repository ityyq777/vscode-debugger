{
  "name": "vscode-debugger-proxy",
  "version": "0.1.0",
  "publisher": "yangyuqi",
  "description": "Enable Claude Code to control VSCode debugger via synchronous blocking HTTP API",
  "repository": "https://github.com/ityyq777/vscode-debugger",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-debugger-proxy.toggle",
        "title": "Toggle Debugger Proxy"
      }
    ],
    "configuration": {
      "title": "Debugger Proxy",
      "properties": {
        "debuggerProxy.port": {
          "type": "number",
          "default": 4711,
          "description": "HTTP server port for the debugger proxy"
        },
        "debuggerProxy.timeout": {
          "type": "number",
          "default": 30000,
          "description": "Default timeout for blocking debug operations (ms)"
        },
        "debuggerProxy.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the debugger proxy server when VSCode loads"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}